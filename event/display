#!/usr/bin/php
<?php
/**
 * Container Quicklinks — Display Event Hook
 * Placed at: /usr/local/emhttp/plugins/container-quicklinks/event/display
 *
 * Unraid calls scripts in /event/display after rendering each page.
 * We use this to inject our nav script tag into the page output.
 *
 * HOW IT WORKS:
 *   Unraid's emhttp outputs a hook point at the bottom of every page.
 *   This script emits a <script> tag that loads our nav injector.
 *   The injector then reads saved links and adds them to the nav bar.
 */
echo '<script src="/plugins/container-quicklinks/js/nav-inject.js?v=' . filemtime('/usr/local/emhttp/plugins/container-quicklinks/js/nav-inject.js') . '"></script>' . "\n";
